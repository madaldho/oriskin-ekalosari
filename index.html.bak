<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Oriskin Ekalokasari Bogor - Klinik kecantikan premium dengan perawatan wajah, laser, dan peeling terbaik di Bogor. Konsultasi gratis sekarang!">
  <meta name="keywords" content="klinik kecantikan bogor, facial bogor, laser wajah bogor, peeling bogor, oriskin bogor">
  <meta name="author" content="Oriskin Ekalokasari Bogor">
  <meta property="og:title" content="Oriskin Ekalokasari Bogor - Klinik Kecantikan Premium">
  <meta property="og:description" content="Perawatan kulit profesional dengan teknologi terkini. 5000+ pasien puas, 10+ tahun pengalaman.">
  <meta property="og:image" content="assets/hero-clinic.png">
  <meta property="og:type" content="website">
  <title>Oriskin Ekalokasari Bogor - Klinik Kecantikan Premium</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    /* ========== RESET & BASE ========== */
    *, *::before, *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --bg: #F7F4EF;
      --bg-warm: #F0EBE3;
      --charcoal: #1F2937;
      --charcoal-light: #374151;
      --terracotta: #C97A5A;
      --terracotta-dark: #B5694B;
      --terracotta-light: #D99A7E;
      --sage: #6E7F63;
      --sage-light: #8A9B80;
      --sage-pale: #E8EDE5;
      --white: #FFFFFF;
      --cream: #FFFAF5;
      --border: #E5E0D8;
      --text-muted: #6B7280;
      --shadow-sm: 0 1px 3px rgba(31,41,55,0.06);
      --shadow-md: 0 4px 16px rgba(31,41,55,0.08);
      --shadow-lg: 0 8px 32px rgba(31,41,55,0.1);
      --shadow-xl: 0 16px 48px rgba(31,41,55,0.12);
      --radius-sm: 8px;
      --radius-md: 12px;
      --radius-lg: 20px;
      --radius-xl: 28px;
      --transition: 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

    html {
      scroll-behavior: smooth;
      -webkit-text-size-adjust: 100%;
    }

    body {
      font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, sans-serif;
      background-color: var(--bg);
      color: var(--charcoal);
      line-height: 1.7;
      font-size: 16px;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    img {
      max-width: 100%;
      height: auto;
      display: block;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    button {
      font-family: inherit;
      cursor: pointer;
      border: none;
      background: none;
    }

    h1, h2, h3, h4, h5 {
      font-family: 'Lora', Georgia, serif;
      font-weight: 600;
      line-height: 1.25;
    }

    /* ========== UTILITY ========== */
    .container {
      width: 100%;
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 20px;
    }

    .section-label {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--terracotta);
      margin-bottom: 12px;
    }

    .section-title {
      font-size: clamp(1.75rem, 4vw, 2.5rem);
      color: var(--charcoal);
      margin-bottom: 16px;
    }

    .section-subtitle {
      font-size: 1.05rem;
      color: var(--text-muted);
      max-width: 560px;
      line-height: 1.7;
    }

    .btn-primary {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 16px 36px;
      background: var(--terracotta);
      color: var(--white);
      font-weight: 600;
      font-size: 0.95rem;
      border-radius: 60px;
      transition: all var(--transition);
      letter-spacing: 0.01em;
    }

    .btn-primary:hover {
      background: var(--terracotta-dark);
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(201,122,90,0.3);
    }

    .btn-secondary {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 14px 32px;
      background: transparent;
      color: var(--charcoal);
      font-weight: 600;
      font-size: 0.95rem;
      border: 1.5px solid var(--border);
      border-radius: 60px;
      transition: all var(--transition);
    }

    .btn-secondary:hover {
      border-color: var(--terracotta);
      color: var(--terracotta);
      transform: translateY(-2px);
    }

    /* ========== SCROLL REVEAL ========== */
    .reveal {
      opacity: 0;
      transform: translateY(32px);
      transition: opacity 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                  transform 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

    .reveal.active {
      opacity: 1;
      transform: translateY(0);
    }

    .reveal-delay-1 { transition-delay: 0.1s; }
    .reveal-delay-2 { transition-delay: 0.2s; }
    .reveal-delay-3 { transition-delay: 0.3s; }
    .reveal-delay-4 { transition-delay: 0.4s; }

    /* ========== NAVBAR ========== */
    .navbar {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 1000;
      padding: 16px 0;
      transition: all 0.4s ease;
    }

    .navbar.scrolled {
      background: rgba(247, 244, 239, 0.82);
      -webkit-backdrop-filter: blur(20px) saturate(180%);
      backdrop-filter: blur(20px) saturate(180%);
      border-bottom: 1px solid rgba(229, 224, 216, 0.5);
      padding: 12px 0;
    }

    .navbar .container {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .nav-brand {
      font-family: 'Lora', serif;
      font-size: 1.4rem;
      font-weight: 700;
      color: var(--charcoal);
      letter-spacing: -0.01em;
    }

    .nav-brand span {
      color: var(--terracotta);
    }

    .nav-links {
      display: none;
      list-style: none;
      gap: 32px;
      align-items: center;
    }

    .nav-links a {
      font-size: 0.875rem;
      font-weight: 500;
      color: var(--charcoal-light);
      transition: color var(--transition);
      position: relative;
    }

    .nav-links a::after {
      content: '';
      position: absolute;
      bottom: -4px;
      left: 0;
      width: 0;
      height: 1.5px;
      background: var(--terracotta);
      transition: width var(--transition);
    }

    .nav-links a:hover {
      color: var(--terracotta);
    }

    .nav-links a:hover::after {
      width: 100%;
    }

    .nav-cta {
      display: none;
      padding: 10px 24px;
      background: var(--terracotta);
      color: var(--white);
      font-weight: 600;
      font-size: 0.85rem;
      border-radius: 60px;
      transition: all var(--transition);
    }

    .nav-cta:hover {
      background: var(--terracotta-dark);
      transform: translateY(-1px);
    }

    .nav-toggle {
      display: flex;
      flex-direction: column;
      gap: 5px;
      padding: 4px;
      cursor: pointer;
      z-index: 1001;
    }

    .nav-toggle span {
      display: block;
      width: 24px;
      height: 2px;
      background: var(--charcoal);
      border-radius: 2px;
      transition: all 0.3s ease;
    }

    .nav-toggle.open span:nth-child(1) {
      transform: rotate(45deg) translate(5px, 5px);
    }

    .nav-toggle.open span:nth-child(2) {
      opacity: 0;
    }

    .nav-toggle.open span:nth-child(3) {
      transform: rotate(-45deg) translate(5px, -5px);
    }

    /* Mobile menu */
    .mobile-menu {
      position: fixed;
      top: 0;
      right: -100%;
      width: 100%;
      height: 100vh;
      background: var(--bg);
      z-index: 999;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: 28px;
      transition: right 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

    .mobile-menu.open {
      right: 0;
    }

    .mobile-menu a {
      font-family: 'Lora', serif;
      font-size: 1.5rem;
      font-weight: 500;
      color: var(--charcoal);
      transition: color var(--transition);
    }

    .mobile-menu a:hover {
      color: var(--terracotta);
    }

    .mobile-menu .btn-primary {
      margin-top: 12px;
    }

    /* ========== HERO ========== */
    .hero {
      position: relative;
      min-height: 100vh;
      display: flex;
      align-items: center;
      overflow: hidden;
    }

    .hero-bg {
      position: absolute;
      inset: 0;
      z-index: 0;
    }

    .hero-bg img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .hero-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        135deg,
        rgba(247, 244, 239, 0.92) 0%,
        rgba(247, 244, 239, 0.75) 50%,
        rgba(247, 244, 239, 0.45) 100%
      );
      z-index: 1;
    }

    .hero-content {
      position: relative;
      z-index: 2;
      max-width: 620px;
      padding: 120px 0 80px;
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 18px;
      background: var(--sage-pale);
      border-radius: 60px;
      font-size: 0.8rem;
      font-weight: 600;
      color: var(--sage);
      margin-bottom: 28px;
    }

    .hero-badge svg {
      width: 14px;
      height: 14px;
    }

    .hero h1 {
      font-size: clamp(2.25rem, 5.5vw, 3.5rem);
      color: var(--charcoal);
      margin-bottom: 20px;
      letter-spacing: -0.02em;
    }

    .hero h1 em {
      font-style: italic;
      color: var(--terracotta);
    }

    .hero-desc {
      font-size: 1.1rem;
      color: var(--charcoal-light);
      margin-bottom: 36px;
      max-width: 480px;
      line-height: 1.8;
    }

    .hero-buttons {
      display: flex;
      flex-wrap: wrap;
      gap: 14px;
      margin-bottom: 48px;
    }

    .hero-info {
      display: flex;
      align-items: center;
      gap: 16px;
      padding: 16px 20px;
      background: rgba(255,255,255,0.7);
      -webkit-backdrop-filter: blur(10px);
      backdrop-filter: blur(10px);
      border-radius: var(--radius-md);
      border: 1px solid var(--border);
      max-width: fit-content;
    }

    .hero-info svg {
      width: 18px;
      height: 18px;
      color: var(--sage);
      flex-shrink: 0;
    }

    .hero-info p {
      font-size: 0.85rem;
      color: var(--charcoal-light);
    }

    .hero-info strong {
      color: var(--charcoal);
    }

    /* ========== TRUST STATS ========== */
    .trust {
      padding: 64px 0;
      background: var(--white);
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
    }

    .trust-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 32px;
      text-align: center;
    }

    .trust-item {
      padding: 24px 16px;
    }

    .trust-number {
      font-family: 'Lora', serif;
      font-size: clamp(2rem, 4vw, 2.75rem);
      font-weight: 700;
      color: var(--terracotta);
      margin-bottom: 8px;
    }

    .trust-label {
      font-size: 0.9rem;
      color: var(--text-muted);
      font-weight: 500;
    }

    .trust-divider {
      display: none;
      width: 1px;
      background: var(--border);
      margin: 0 auto;
    }

    /* ========== SERVICES ========== */
    .services {
      padding: 96px 0;
    }

    .services-header {
      text-align: center;
      margin-bottom: 56px;
    }

    .services-header .section-subtitle {
      margin: 0 auto;
    }

    .services-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .service-card {
      background: var(--white);
      border-radius: var(--radius-lg);
      overflow: hidden;
      border: 1px solid var(--border);
      transition: all var(--transition);
    }

    .service-card:hover {
      transform: translateY(-6px);
      box-shadow: var(--shadow-lg);
      border-color: transparent;
    }

    .service-card-img {
      position: relative;
      height: 220px;
      overflow: hidden;
    }

    .service-card-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.6s ease;
    }

    .service-card:hover .service-card-img img {
      transform: scale(1.05);
    }

    .service-card-badge {
      position: absolute;
      top: 16px;
      left: 16px;
      padding: 6px 14px;
      background: rgba(255,255,255,0.9);
      -webkit-backdrop-filter: blur(8px);
      backdrop-filter: blur(8px);
      border-radius: 60px;
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--sage);
    }

    .service-card-body {
      padding: 28px 24px;
    }

    .service-card h3 {
      font-size: 1.25rem;
      margin-bottom: 10px;
    }

    .service-card p {
      font-size: 0.9rem;
      color: var(--text-muted);
      line-height: 1.7;
      margin-bottom: 20px;
    }

    .service-link {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-size: 0.875rem;
      font-weight: 600;
      color: var(--terracotta);
      transition: gap var(--transition);
    }

    .service-link:hover {
      gap: 14px;
    }

    .service-link svg {
      width: 16px;
      height: 16px;
      transition: transform var(--transition);
    }

    .service-link:hover svg {
      transform: translateX(4px);
    }

    /* ========== BEFORE AFTER ========== */
    .before-after {
      padding: 96px 0;
      background: var(--white);
    }

    .ba-wrapper {
      display: grid;
      grid-template-columns: 1fr;
      gap: 48px;
      align-items: center;
    }

    .ba-image {
      border-radius: var(--radius-lg);
      overflow: hidden;
      box-shadow: var(--shadow-lg);
    }

    .ba-image img {
      width: 100%;
      height: auto;
    }

    .ba-content {
      max-width: 480px;
    }

    .ba-content .section-title {
      margin-bottom: 20px;
    }

    .ba-content p {
      color: var(--text-muted);
      margin-bottom: 16px;
      line-height: 1.8;
    }

    .ba-stats {
      display: flex;
      gap: 32px;
      margin: 32px 0;
      padding: 24px 0;
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
    }

    .ba-stat strong {
      display: block;
      font-family: 'Lora', serif;
      font-size: 1.5rem;
      color: var(--terracotta);
      margin-bottom: 4px;
    }

    .ba-stat span {
      font-size: 0.85rem;
      color: var(--text-muted);
    }

    /* ========== DOCTOR ========== */
    .doctor {
      padding: 96px 0;
    }

    .doctor-wrapper {
      display: grid;
      grid-template-columns: 1fr;
      gap: 48px;
      align-items: center;
    }

    .doctor-image {
      position: relative;
    }

    .doctor-image img {
      width: 100%;
      border-radius: var(--radius-xl);
      box-shadow: var(--shadow-lg);
    }

    .doctor-accent {
      position: absolute;
      bottom: -16px;
      right: -16px;
      width: 120px;
      height: 120px;
      background: var(--sage-pale);
      border-radius: 50%;
      z-index: -1;
    }

    .doctor-content h2 {
      font-size: clamp(1.75rem, 3.5vw, 2.25rem);
      margin-bottom: 8px;
    }

    .doctor-title {
      font-size: 1rem;
      color: var(--terracotta);
      font-weight: 600;
      margin-bottom: 20px;
    }

    .doctor-content p {
      color: var(--text-muted);
      margin-bottom: 16px;
      line-height: 1.8;
    }

    .doctor-credentials {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 24px;
    }

    .credential-tag {
      padding: 8px 16px;
      background: var(--sage-pale);
      border-radius: 60px;
      font-size: 0.8rem;
      font-weight: 600;
      color: var(--sage);
    }

    /* ========== PROMO ========== */
    .promo {
      padding: 96px 0;
      background: var(--white);
    }

    .promo-card {
      background: linear-gradient(135deg, var(--charcoal) 0%, #2D3748 100%);
      border-radius: var(--radius-xl);
      padding: 48px 32px;
      text-align: center;
      position: relative;
      overflow: hidden;
    }

    .promo-card::before {
      content: '';
      position: absolute;
      top: -50%;
      right: -30%;
      width: 400px;
      height: 400px;
      background: radial-gradient(circle, rgba(201,122,90,0.15) 0%, transparent 70%);
      border-radius: 50%;
    }

    .promo-card::after {
      content: '';
      position: absolute;
      bottom: -30%;
      left: -20%;
      width: 300px;
      height: 300px;
      background: radial-gradient(circle, rgba(110,127,99,0.1) 0%, transparent 70%);
      border-radius: 50%;
    }

    .promo-card > * {
      position: relative;
      z-index: 1;
    }

    .promo-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 20px;
      background: rgba(201,122,90,0.15);
      border: 1px solid rgba(201,122,90,0.3);
      border-radius: 60px;
      font-size: 0.8rem;
      font-weight: 600;
      color: var(--terracotta-light);
      margin-bottom: 24px;
    }

    .promo-card h2 {
      font-size: clamp(1.75rem, 4vw, 2.5rem);
      color: var(--white);
      margin-bottom: 16px;
    }

    .promo-card h2 em {
      font-style: italic;
      color: var(--terracotta-light);
    }

    .promo-card > p {
      color: rgba(255,255,255,0.7);
      max-width: 520px;
      margin: 0 auto 32px;
      line-height: 1.7;
    }

    .promo-card .btn-primary {
      background: var(--terracotta);
      font-size: 1rem;
      padding: 18px 42px;
    }

    .promo-card .btn-primary:hover {
      background: var(--terracotta-light);
    }

    .promo-terms {
      margin-top: 20px;
      font-size: 0.8rem;
      color: rgba(255,255,255,0.4);
    }

    /* ========== TESTIMONIALS ========== */
    .testimonials {
      padding: 96px 0;
    }

    .testimonials-header {
      text-align: center;
      margin-bottom: 56px;
    }

    .testimonials-header .section-subtitle {
      margin: 0 auto;
    }

    .testi-carousel {
      position: relative;
      overflow: hidden;
    }

    .testi-track {
      display: flex;
      transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

    .testi-slide {
      min-width: 100%;
      padding: 0 8px;
    }

    .testi-card {
      background: var(--white);
      border-radius: var(--radius-lg);
      padding: 36px 32px;
      border: 1px solid var(--border);
      height: 100%;
    }

    .testi-stars {
      display: flex;
      gap: 4px;
      margin-bottom: 20px;
    }

    .testi-stars svg {
      width: 18px;
      height: 18px;
      fill: #F59E0B;
    }

    .testi-text {
      font-size: 1rem;
      color: var(--charcoal-light);
      line-height: 1.8;
      margin-bottom: 24px;
      font-style: italic;
    }

    .testi-author {
      display: flex;
      align-items: center;
      gap: 14px;
    }

    .testi-avatar {
      width: 48px;
      height: 48px;
      border-radius: 50%;
      background: var(--sage-pale);
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Lora', serif;
      font-weight: 700;
      font-size: 1.1rem;
      color: var(--sage);
      flex-shrink: 0;
    }

    .testi-name {
      font-weight: 600;
      font-size: 0.95rem;
      color: var(--charcoal);
    }

    .testi-role {
      font-size: 0.8rem;
      color: var(--text-muted);
    }

    .testi-dots {
      display: flex;
      justify-content: center;
      gap: 10px;
      margin-top: 32px;
    }

    .testi-dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: var(--border);
      border: none;
      cursor: pointer;
      transition: all var(--transition);
      padding: 0;
    }

    .testi-dot.active {
      background: var(--terracotta);
      width: 28px;
      border-radius: 5px;
    }

    /* ========== FAQ ========== */
    .faq {
      padding: 96px 0;
      background: var(--white);
    }

    .faq-header {
      text-align: center;
      margin-bottom: 56px;
    }

    .faq-header .section-subtitle {
      margin: 0 auto;
    }

    .faq-list {
      max-width: 720px;
      margin: 0 auto;
    }

    .faq-item {
      border-bottom: 1px solid var(--border);
    }

    .faq-item:first-child {
      border-top: 1px solid var(--border);
    }

    .faq-question {
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 22px 0;
      background: none;
      border: none;
      cursor: pointer;
      text-align: left;
      font-size: 1rem;
      font-weight: 600;
      color: var(--charcoal);
      font-family: 'Plus Jakarta Sans', sans-serif;
      gap: 16px;
      transition: color var(--transition);
    }

    .faq-question:hover {
      color: var(--terracotta);
    }

    .faq-icon {
      width: 28px;
      height: 28px;
      border-radius: 50%;
      background: var(--bg);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      transition: all var(--transition);
    }

    .faq-icon svg {
      width: 14px;
      height: 14px;
      transition: transform 0.3s ease;
    }

    .faq-item.open .faq-icon {
      background: var(--terracotta);
    }

    .faq-item.open .faq-icon svg {
      transform: rotate(180deg);
      stroke: white;
    }

    .faq-answer {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                  padding 0.4s ease;
    }

    .faq-answer-inner {
      padding-bottom: 22px;
      color: var(--text-muted);
      line-height: 1.8;
      font-size: 0.95rem;
    }

    /* ========== LOCATION ========== */
    .location {
      padding: 96px 0;
    }

    .location-header {
      text-align: center;
      margin-bottom: 56px;
    }

    .location-header .section-subtitle {
      margin: 0 auto;
    }

    .location-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .location-map {
      border-radius: var(--radius-lg);
      overflow: hidden;
      box-shadow: var(--shadow-md);
      border: 1px solid var(--border);
    }

    .location-map img {
      width: 100%;
      height: 280px;
      object-fit: cover;
    }

    .location-details {
      display: flex;
      flex-direction: column;
      gap: 24px;
    }

    .location-item {
      display: flex;
      gap: 16px;
      align-items: flex-start;
    }

    .location-icon {
      width: 44px;
      height: 44px;
      background: var(--sage-pale);
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .location-icon svg {
      width: 20px;
      height: 20px;
      color: var(--sage);
    }

    .location-item h4 {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 0.95rem;
      font-weight: 600;
      margin-bottom: 4px;
    }

    .location-item p {
      font-size: 0.9rem;
      color: var(--text-muted);
      line-height: 1.6;
    }

    .location-hours {
      display: grid;
      grid-template-columns: 1fr;
      gap: 12px;
      margin-top: 8px;
    }

    .hour-row {
      display: flex;
      justify-content: space-between;
      padding: 10px 16px;
      background: var(--bg);
      border-radius: var(--radius-sm);
      font-size: 0.875rem;
    }

    .hour-row .day {
      font-weight: 600;
      color: var(--charcoal);
    }

    .hour-row .time {
      color: var(--text-muted);
    }

    .hour-row.closed .time {
      color: var(--terracotta);
      font-weight: 600;
    }

    /* ========== FINAL CTA ========== */
    .final-cta {
      padding: 96px 0;
      background: var(--sage-pale);
    }

    .final-cta-content {
      text-align: center;
      max-width: 600px;
      margin: 0 auto;
    }

    .final-cta h2 {
      font-size: clamp(1.75rem, 4vw, 2.5rem);
      margin-bottom: 16px;
    }

    .final-cta p {
      color: var(--charcoal-light);
      margin-bottom: 36px;
      line-height: 1.7;
      font-size: 1.05rem;
    }

    .final-cta .btn-primary {
      padding: 18px 42px;
      font-size: 1rem;
    }

    /* ========== FOOTER ========== */
    .footer {
      background: var(--charcoal);
      padding: 64px 0 32px;
      color: rgba(255,255,255,0.7);
    }

    .footer-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 40px;
      margin-bottom: 48px;
    }

    .footer-brand {
      font-family: 'Lora', serif;
      font-size: 1.4rem;
      font-weight: 700;
      color: var(--white);
      margin-bottom: 12px;
    }

    .footer-brand span {
      color: var(--terracotta-light);
    }

    .footer-desc {
      font-size: 0.9rem;
      line-height: 1.7;
      max-width: 320px;
    }

    .footer-heading {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 0.85rem;
      font-weight: 700;
      color: var(--white);
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin-bottom: 20px;
    }

    .footer-links {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .footer-links a {
      font-size: 0.9rem;
      transition: color var(--transition);
    }

    .footer-links a:hover {
      color: var(--terracotta-light);
    }

    .footer-bottom {
      padding-top: 32px;
      border-top: 1px solid rgba(255,255,255,0.1);
      display: flex;
      flex-direction: column;
      gap: 16px;
      align-items: center;
      text-align: center;
    }

    .footer-bottom p {
      font-size: 0.8rem;
    }

    .footer-social {
      display: flex;
      gap: 12px;
    }

    .footer-social a {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: rgba(255,255,255,0.08);
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all var(--transition);
    }

    .footer-social a:hover {
      background: var(--terracotta);
    }

    .footer-social svg {
      width: 18px;
      height: 18px;
      fill: rgba(255,255,255,0.7);
    }

    .footer-social a:hover svg {
      fill: white;
    }

    /* ========== STICKY WA BUTTON ========== */
    .wa-sticky {
      position: fixed;
      bottom: 28px;
      right: 28px;
      z-index: 900;
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .wa-tooltip {
      background: var(--white);
      padding: 10px 18px;
      border-radius: var(--radius-md);
      box-shadow: var(--shadow-lg);
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--charcoal);
      white-space: nowrap;
      opacity: 0;
      transform: translateX(10px);
      transition: all var(--transition);
      pointer-events: none;
    }

    .wa-sticky:hover .wa-tooltip {
      opacity: 1;
      transform: translateX(0);
    }

    .wa-btn {
      width: 60px;
      height: 60px;
      border-radius: 50%;
      background: #25D366;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 4px 20px rgba(37,211,102,0.35);
      transition: all var(--transition);
      position: relative;
    }

    .wa-btn:hover {
      transform: scale(1.08);
      box-shadow: 0 6px 28px rgba(37,211,102,0.45);
    }

    .wa-btn svg {
      width: 30px;
      height: 30px;
      fill: white;
    }

    .wa-btn::before {
      content: '';
      position: absolute;
      width: 100%;
      height: 100%;
      border-radius: 50%;
      background: #25D366;
      animation: waPulse 2s infinite;
      z-index: -1;
    }

    @keyframes waPulse {
      0% {
        transform: scale(1);
        opacity: 0.5;
      }
      70% {
        transform: scale(1.5);
        opacity: 0;
      }
      100% {
        transform: scale(1.5);
        opacity: 0;
      }
    }

    /* ========== MEDIA QUERIES ========== */
    @media (min-width: 640px) {
      .container {
        padding: 0 32px;
      }

      .services-grid {
        grid-template-columns: repeat(2, 1fr);
      }

      .testi-slide {
        min-width: 50%;
      }

      .footer-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (min-width: 768px) {
      .ba-wrapper {
        grid-template-columns: 1fr 1fr;
      }

      .doctor-wrapper {
        grid-template-columns: 1fr 1fr;
      }

      .location-grid {
        grid-template-columns: 1fr 1fr;
      }

      .location-map img {
        height: 100%;
        min-height: 320px;
      }
    }

    @media (min-width: 1024px) {
      .container {
        padding: 0 48px;
      }

      .nav-links {
        display: flex;
      }

      .nav-cta {
        display: inline-flex;
      }

      .nav-toggle {
        display: none;
      }

      .services-grid {
        grid-template-columns: repeat(4, 1fr);
      }

      .service-card-img {
        height: 200px;
      }

      .testi-slide {
        min-width: 33.333%;
      }

      .promo-card {
        padding: 72px 64px;
      }

      .footer-grid {
        grid-template-columns: 2fr 1fr 1fr 1fr;
      }

      .footer-bottom {
        flex-direction: row;
        justify-content: space-between;
      }
    }
  </style>
</head>
