---
const waLink = 'https://wa.me/6281288045939?text=Halo%20Oriskin%2C%20saya%20mau%20konsultasi';

const services = [
  {
    image: '/service-facial.png',
    alt: 'Facial treatment premium di Oriskin Bogor',
    badge: 'Terpopuler',
    title: 'Facial Treatment',
    desc: 'Deep cleansing facial dengan teknik terkini untuk membersihkan, menutrisi, dan mencerahkan kulit wajah secara menyeluruh.',
  },
  {
    image: '/service-laser.png',
    alt: 'Laser treatment modern di Oriskin Bogor',
    badge: 'Teknologi Terbaru',
    title: 'Laser Treatment',
    desc: 'Teknologi laser canggih untuk mengatasi flek hitam, bekas jerawat, pori-pori besar, dan meremajakan kulit wajah Anda.',
  },
  {
    image: '/service-peeling.png',
    alt: 'Chemical peeling treatment di Oriskin Bogor',
    badge: 'Best Seller',
    title: 'Chemical Peeling',
    desc: 'Eksfoliasi profesional untuk mengangkat sel kulit mati, menyamarkan kerutan halus, dan memperbaiki tekstur kulit.',
  },
  {
    image: '/clinic-exterior.png',
    alt: 'Konsultasi kulit dengan dokter ahli di Oriskin Bogor',
    badge: 'Gratis',
    title: 'Konsultasi Dokter',
    desc: 'Konsultasi langsung dengan dokter spesialis kulit berpengalaman untuk analisis kondisi kulit dan rekomendasi perawatan.',
  },
];
---

<section class="services" id="layanan">
  <div class="container">
    <div class="services-header reveal">
      <p class="section-label">Layanan Kami</p>
      <h2 class="section-title">Perawatan Terbaik untuk Kulit Anda</h2>
      <p class="section-subtitle">Setiap perawatan dirancang khusus sesuai kebutuhan kulit Anda dengan teknologi terkini dan bahan berkualitas tinggi.</p>
    </div>
    <div class="services-grid">
      {services.map((service, i) => (
        <article class={`service-card reveal ${i > 0 ? `reveal-delay-${i}` : ''}`}>
          <div class="service-card-img">
            <img src={service.image} alt={service.alt} loading="lazy" width="400" height="300" />
            <span class="service-card-badge">{service.badge}</span>
          </div>
          <div class="service-card-body">
            <h3>{service.title}</h3>
            <p>{service.desc}</p>
            <a href={waLink} class="service-link" target="_blank" rel="noopener">
              Booking Sekarang
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .services {
    padding: 96px 0;
  }

  .services-header {
    text-align: center;
    margin-bottom: 56px;
  }

  .services-header .section-subtitle {
    margin: 0 auto;
  }

  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }

  .service-card {
    background: var(--white);
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--border);
    transition: all var(--transition);
  }

  .service-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-lg);
    border-color: transparent;
  }

  .service-card-img {
    position: relative;
    height: 220px;
    overflow: hidden;
  }

  .service-card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .service-card:hover .service-card-img img {
    transform: scale(1.05);
  }

  .service-card-badge {
    position: absolute;
    top: 16px;
    left: 16px;
    padding: 6px 14px;
    background: rgba(255,255,255,0.9);
    -webkit-backdrop-filter: blur(8px);
    backdrop-filter: blur(8px);
    border-radius: 60px;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--sage);
  }

  .service-card-body {
    padding: 28px 24px;
  }

  .service-card h3 {
    font-size: 1.25rem;
    margin-bottom: 10px;
  }

  .service-card p {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 20px;
  }

  .service-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--terracotta);
    transition: gap var(--transition);
  }

  .service-link:hover {
    gap: 14px;
  }

  .service-link svg {
    width: 16px;
    height: 16px;
    transition: transform var(--transition);
  }

  .service-link:hover svg {
    transform: translateX(4px);
  }

  @media (min-width: 640px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .services-grid {
      grid-template-columns: repeat(4, 1fr);
    }

    .service-card-img {
      height: 200px;
    }
  }
</style>
