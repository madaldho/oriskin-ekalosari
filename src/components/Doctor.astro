---
const doctors = [
  {
    id: 1,
    name: 'dr. Sarah Wijaya, Sp.KK',
    role: 'Dokter Spesialis Kulit',
    description: 'Spesialis dermatologi dengan 10+ tahun pengalaman dalam perawatan kulit klinis dan estetika.',
    image: '/doctor-portrait.png',
  },
  {
    id: 2,
    name: 'dr. Nina Kusuma, Sp.DV',
    role: 'Dokter Estetika',
    description: 'Ahli laser treatment dan anti-aging dengan sertifikasi internasional dari Eropa.',
    image: '/doctor-portrait.png',
  },
  {
    id: 3,
    name: 'dr. Amanda Putri, M.Kes',
    role: 'Dokter Kecantikan',
    description: 'Fokus pada chemical peeling dan acne treatment, melayani 3000+ pasien setiap tahun.',
    image: '/doctor-portrait.png',
  },
  {
    id: 4,
    name: 'dr. Lisa Anggraini, Sp.KK',
    role: 'Dokter Anti-Aging',
    description: 'Tersertifikasi internasional untuk treatment anti-aging dan rejuvenasi kulit wajah.',
    image: '/doctor-portrait.png',
  },
  {
    id: 5,
    name: 'dr. Diana Sari, M.Kes',
    role: 'Dokter Laser Specialist',
    description: 'Berpengalaman lebih dari 8 tahun dalam berbagai prosedur laser estetika modern.',
    image: '/doctor-portrait.png',
  },
];
---

<section class="doctor" id="dokter">
  <!-- Background blur pink glow -->
  <div class="doctor-bg-glow"></div>

  <div class="container">
    <div class="doctor-header reveal">
      <div class="header-icon-wrapper">
        <svg xmlns="http://www.w3.org/2000/svg" class="header-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
        </svg>
        <h2 class="section-title">
          Tim <span class="gradient-text">Dokter Ahli</span>
        </h2>
      </div>
      <p class="section-subtitle">Profesional tersertifikasi untuk perawatan kulit Anda</p>
    </div>

    <!-- Carousel Container -->
    <div 
      class="carousel-wrapper" 
      id="carouselWrapper"
    >
      <div class="carousel-track" id="carouselTrack">
        {doctors.map((doctor, index) => (
          <div 
            class="doctor-card" 
            data-index={index}
          >
            <!-- Image -->
            <img src={doctor.image} alt={doctor.name} class="doctor-img" />
            
            <!-- Gradient overlay -->
            <div class="doctor-overlay"></div>
            
            <!-- Content -->
            <div class="doctor-content">
              <!-- Stars -->
              <div class="doctor-stars">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
              </div>

              <h3 class="doctor-name">{doctor.name}</h3>
              
              <p class="doctor-role">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>
                {doctor.role}
              </p>

              <!-- Description - hanya muncul saat center -->
              <div class="doctor-desc-wrapper">
                <p class="doctor-desc">{doctor.description}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Pagination Indicators -->
    <div class="carousel-indicators">
      {doctors.map((_, index) => (
        <button 
          class="indicator" 
          data-index={index}
          aria-label={`Slide ${index + 1}`}
        ></button>
      ))}
    </div>
  </div>
</section>

<script>
  const track = document.getElementById('carouselTrack');
  const wrapper = document.getElementById('carouselWrapper');
  const cards = track?.querySelectorAll('.doctor-card');
  const indicators = document.querySelectorAll('.indicator');
  
  let activeIndex = 0;
  let autoplayInterval: number | undefined;
  let isPaused = false;

  function getOffset(index: number): number {
    if (!cards) return 0;
    let diff = index - activeIndex;
    const length = cards.length;
    
    // Infinite wrap logic
    if (diff > length / 2) diff -= length;
    if (diff < -length / 2) diff += length;
    
    return diff;
  }

  function updateCarousel() {
    if (!cards || cards.length === 0) return;

    cards.forEach((card, index) => {
      const offset = getOffset(index);
      const isCenter = offset === 0;
      
      // Position: 115% untuk spacing antar card
      const translateX = offset * 115;
      
      // Scale: center = 1, sides = 0.85
      const scale = isCenter ? 1 : 0.85;
      
      // Opacity: center = 1, sides (-1, +1) = 0.4, others = 0
      const opacity = Math.abs(offset) > 1 ? 0 : (isCenter ? 1 : 0.4);
      
      // Z-index: center highest
      const zIndex = 10 - Math.abs(offset);

      const element = card as HTMLElement;
      element.style.transform = `translate(calc(-50% + ${translateX}%), -50%) scale(${scale})`;
      element.style.opacity = String(opacity);
      element.style.zIndex = String(zIndex);
      element.style.visibility = Math.abs(offset) > 2 ? 'hidden' : 'visible';

      // Toggle border dan shadow untuk center card
      if (isCenter) {
        element.classList.add('active');
      } else {
        element.classList.remove('active');
      }
    });

    // Update indicators
    indicators.forEach((ind, i) => {
      if (i === activeIndex) {
        ind.classList.add('active');
      } else {
        ind.classList.remove('active');
      }
    });
  }

  function nextSlide() {
    if (!cards) return;
    activeIndex = (activeIndex + 1) % cards.length;
    updateCarousel();
  }

  function goToSlide(index: number) {
    activeIndex = index;
    updateCarousel();
  }

  function startAutoplay() {
    stopAutoplay();
    autoplayInterval = window.setInterval(() => {
      if (!isPaused) {
        nextSlide();
      }
    }, 3000);
  }

  function stopAutoplay() {
    if (autoplayInterval) {
      clearInterval(autoplayInterval);
    }
  }

  // Click handlers
  cards?.forEach((card) => {
    card.addEventListener('click', () => {
      const index = parseInt((card as HTMLElement).dataset.index || '0');
      goToSlide(index);
    });
  });

  indicators.forEach((ind) => {
    ind.addEventListener('click', () => {
      const index = parseInt((ind as HTMLElement).dataset.index || '0');
      goToSlide(index);
    });
  });

  // Pause on hover
  wrapper?.addEventListener('mouseenter', () => {
    isPaused = true;
  });
  
  wrapper?.addEventListener('mouseleave', () => {
    isPaused = false;
  });

  // Initialize
  updateCarousel();
  startAutoplay();
</script>

<style>
  .doctor {
    position: relative;
    padding: 96px 0;
    background: var(--bg);
    overflow: hidden;
  }

  /* Background glow blur effect (pink) */
  .doctor-bg-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 80vw;
    height: 80vh;
    background: rgba(232, 123, 123, 0.1);
    filter: blur(120px);
    border-radius: 50%;
    pointer-events: none;
    z-index: 0;
  }

  .container {
    position: relative;
    z-index: 1;
  }

  /* Header */
  .doctor-header {
    text-align: center;
    margin-bottom: 56px;
  }

  .header-icon-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-bottom: 8px;
  }

  .header-icon {
    width: 32px;
    height: 32px;
    color: var(--pink);
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  .gradient-text {
    background: linear-gradient(90deg, var(--pink) 0%, var(--pink-dark) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .section-subtitle {
    color: var(--text-muted);
    font-size: 0.95rem;
  }

  /* Carousel */
  .carousel-wrapper {
    position: relative;
    width: 100%;
    height: 70vh;
    max-height: 700px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 64px;
  }

  .carousel-track {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .doctor-card {
    position: absolute;
    top: 50%;
    left: 50%;
    width: clamp(240px, 30vw, 320px);
    aspect-ratio: 1 / 1.9;
    border-radius: 32px;
    overflow: hidden;
    cursor: pointer;
    transition: all 0.7s cubic-bezier(0.25, 1, 0.5, 1);
    transform: translate(-50%, -50%);
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);
  }

  .doctor-card.active {
    border: 4px solid var(--pink);
    box-shadow: 0 0 40px rgba(232, 123, 123, 0.5);
  }

  .doctor-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Gradient overlay - dari transparent ke dark di bawah */
  .doctor-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      transparent 0%,
      rgba(45, 42, 50, 0.4) 40%,
      rgba(45, 42, 50, 0.95) 100%
    );
    pointer-events: none;
  }

  .doctor-content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 24px;
    z-index: 2;
  }

  /* Stars */
  .doctor-stars {
    display: flex;
    gap: 4px;
    margin-bottom: 12px;
  }

  .doctor-stars svg {
    width: 16px;
    height: 16px;
    color: var(--pink);
  }

  .doctor-name {
    font-size: clamp(1.3rem, 2.5vw, 1.6rem);
    font-weight: 700;
    color: var(--white);
    margin-bottom: 4px;
    line-height: 1.2;
  }

  .doctor-role {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--pink-light);
    font-weight: 600;
    font-size: 0.9rem;
    margin-bottom: 12px;
  }

  .doctor-role svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  /* Description wrapper - animasi expand/collapse */
  .doctor-desc-wrapper {
    max-height: 0;
    overflow: hidden;
    transition: all 0.5s cubic-bezier(0.25, 1, 0.5, 1);
    opacity: 0;
  }

  .doctor-card.active .doctor-desc-wrapper {
    max-height: 200px;
    opacity: 1;
    margin-top: 8px;
  }

  .doctor-desc {
    font-size: 0.85rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.8);
    border-top: 1px solid rgba(255, 255, 255, 0.2);
    padding-top: 12px;
  }

  /* Pagination Indicators */
  .carousel-indicators {
    display: flex;
    gap: 12px;
    justify-content: center;
    margin-top: 48px;
  }

  .indicator {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: rgba(100, 100, 100, 0.3);
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
    padding: 0;
  }

  .indicator:hover {
    background: rgba(232, 123, 123, 0.4);
  }

  .indicator.active {
    width: 32px;
    height: 10px;
    border-radius: 8px;
    background: linear-gradient(90deg, var(--pink) 0%, var(--pink-dark) 100%);
    box-shadow: 0 0 12px rgba(236, 72, 153, 0.8);
  }

  @media (max-width: 767px) {
    .doctor {
      padding: 84px 0;
    }

    .doctor-header {
      margin-bottom: 36px;
    }

    .carousel-wrapper {
      height: 60vh;
      max-height: 600px;
      margin-top: 48px;
    }

    .doctor-card {
      width: clamp(260px, 75vw, 300px);
    }

    .doctor-content {
      padding: 20px;
    }

    .doctor-name {
      font-size: 1.25rem;
    }

    .doctor-desc {
      font-size: 0.8rem;
    }

    .carousel-indicators {
      margin-top: 36px;
    }
  }

  @media (max-width: 480px) {
    .carousel-wrapper {
      height: 55vh;
      max-height: 550px;
    }

    .doctor-card {
      width: clamp(240px, 85vw, 280px);
    }
  }
</style>
