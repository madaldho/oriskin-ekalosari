---
const waLink = 'https://wa.me/6281288045939?text=Halo%20Oriskin%2C%20saya%20sudah%20siap%20reservasi.%20Kapan%20bisa%3F';
---

<section class="hero" id="hero">
  <div class="hero-bg">
    <img src="/hero-clinic.png" alt="Oriskin Ekalokasari Bogor" width="1920" height="1080" loading="eager" />
  </div>
  <div class="hero-overlay"></div>
  <div class="container">
    <div class="hero-content reveal">
      <h1 class="reveal reveal-delay-1">Perawatan Kulit Profesional <em>di Bogor</em></h1>
      <p class="hero-desc reveal reveal-delay-2">Oriskin Ekalokasari hadir dengan dokter spesialis kulit, teknologi terkini, dan harga yang tetap masuk akal. Reservasi sekarang, treatment langsung!</p>
      <div class="hero-buttons reveal reveal-delay-3">
        <a href={waLink} class="btn-primary" target="_blank" rel="noopener">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51l-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.981.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
          Reservasi Sekarang
        </a>
        <a href="#layanan" class="btn-secondary">Lihat Layanan</a>
      </div>
      <div class="hero-schedule reveal reveal-delay-4">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        <span>Senin – Sabtu, 09:00 – 22:00 WIB</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 92vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
  }

  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(45,42,50,0.32) 0%,
      rgba(45,42,50,0.58) 100%
    );
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 620px;
    padding: 140px 0 80px;
  }

  .hero h1 {
    font-size: clamp(2.2rem, 5vw, 3.4rem);
    color: var(--white);
    margin-bottom: 18px;
    letter-spacing: -0.02em;
    line-height: 1.15;
  }

  .hero h1 em {
    font-style: italic;
    color: var(--pink-pale);
  }

  .hero-desc {
    font-size: 1.05rem;
    color: rgba(255,255,255,0.85);
    line-height: 1.75;
    margin-bottom: 32px;
    max-width: 500px;
  }

  .hero-buttons {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 28px;
  }

  .hero-buttons .btn-secondary {
    color: var(--white);
    border-color: rgba(255,255,255,0.4);
  }

  .hero-buttons .btn-secondary:hover {
    background: rgba(255,255,255,0.12);
    border-color: rgba(255,255,255,0.6);
  }

  .hero-schedule {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 10px 20px;
    background: rgba(255,255,255,0.12);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,0.18);
    border-radius: 60px;
    font-size: 0.88rem;
    color: rgba(255,255,255,0.9);
    font-weight: 500;
  }

  .hero-schedule svg {
    width: 16px;
    height: 16px;
    color: var(--pink-pale);
    flex-shrink: 0;
  }

  @media (max-width: 767px) {
    .hero {
      min-height: 100dvh;
      align-items: center;
    }

    .hero-content {
      padding: 100px 0 48px;
    }

    .hero h1 {
      font-size: clamp(1.9rem, 8vw, 2.6rem);
    }

    .hero-desc {
      font-size: 0.95rem;
      margin-bottom: 24px;
    }
  }

  @media (min-width: 1024px) {
    .hero {
      min-height: 100vh;
    }

    .hero-content {
      padding: 160px 0 100px;
    }
  }
</style>
