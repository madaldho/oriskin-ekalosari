---
const testimonials = [
  {
    text: "Cozy place, very good experience, nice people. I'd love to recommend this treatment for you all",
    photo: '/reviewers/vina.jpg',
    name: 'Vina Yustika Dewi',
    source: 'Google Maps',
  },
  {
    text: 'Cozy place with excellent service. There are variety of treatments offered such as facial treatments etc.',
    photo: '/reviewers/rai.jpg',
    name: 'Rai Indah Nurbani',
    source: 'Google Maps',
  },
  {
    text: 'The staff was helpful and very informative. They will recommend any treatment based on your skin condition. They also recommend payment options for your treatment. Great, thanks!',
    photo: '/reviewers/lailita.jpg',
    name: 'Lailita Nurul F',
    source: 'Google Maps',
  },
  {
    text: 'Staffnya very very kind and informative!! Such a cozy place to do facial, skincare, and especially self reward 🫶',
    photo: '/reviewers/angelia.jpg',
    name: 'Angelia Trisandi',
    source: 'Google Maps',
  },
  {
    text: 'First time facial treatment here. Nice treatment and service. Very worth it, would love to come back again!',
    photo: '/reviewers/cantika.jpg',
    name: 'Cantika NZ',
    source: 'Google Maps',
  },
  {
    text: 'Good and friendly service, staff, doctors and everyone provided a pleasant service for the first time.',
    photo: '/reviewers/anggraeni.jpg',
    name: 'Anggraeni Pramono',
    source: 'Google Maps',
  },
  {
    text: 'Thank you Oriskin, the place and service are all good.',
    photo: '/reviewers/rizki.jpg',
    name: 'Rizki Handayani',
    source: 'Google Maps',
  },
  {
    text: 'Fresh, attractive care and friendly service. Highly recommended!',
    photo: '/reviewers/rima.jpg',
    name: 'Rima Lianawati',
    source: 'Google Maps',
  },
];
---

<section class="testimonials" id="testimoni">
  <div class="container">
    <div class="testimonials-header reveal">
      <p class="section-label">Testimoni</p>
      <h2 class="section-title">Apa Kata Mereka</h2>
      <p class="section-subtitle">Ulasan asli dari pasien di Google Maps — bukan rekayasa.</p>
    </div>
    <div class="testi-grid">
      {testimonials.map((testi, i) => (
        <div class={`testi-card reveal ${i > 0 ? `reveal-delay-${Math.min(i, 7)}` : ''}`}>
          <div class="testi-stars" aria-label="5 dari 5 bintang">
            {Array.from({ length: 5 }).map(() => (
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2L15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2z"/></svg>
            ))}
          </div>
          <p class="testi-text">{testi.text}</p>
          <div class="testi-author">
            <img src={testi.photo} alt={testi.name} class="testi-avatar" loading="lazy" width="40" height="40" />
            <div>
              <p class="testi-name">{testi.name}</p>
              <p class="testi-src">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
                {testi.source}
              </p>
            </div>
          </div>
        </div>
      ))}
    </div>
    <p class="testi-note reveal">Sumber: <a href="https://maps.google.com/maps/place/?q=place_id:ChIJ-y1mfubFaS4RebW05q__szw" target="_blank" rel="noopener">Google Maps Reviews</a> · Rating 5.0 dari 3.300+ ulasan</p>
  </div>
</section>

<style>
  .testimonials {
    padding: 96px 0;
  }

  .testimonials-header {
    text-align: center;
    margin-bottom: 48px;
  }

  .testimonials-header .section-subtitle {
    margin: 0 auto;
  }

  .testi-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    align-items: stretch;
  }

  .testi-card {
    background: var(--white);
    border-radius: var(--radius-lg);
    padding: 24px;
    border: 1px solid var(--border);
    transition: all var(--transition);
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .testi-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: rgba(232,123,123,0.15);
  }

  .testi-stars {
    display: flex;
    gap: 2px;
    margin-bottom: 14px;
  }

  .testi-stars svg {
    width: 16px;
    height: 16px;
    fill: #F59E0B;
    stroke: none;
  }

  .testi-text {
    font-size: 0.88rem;
    color: var(--charcoal);
    line-height: 1.7;
    margin-bottom: 18px;
    font-style: italic;
    font-weight: 300;
    flex: 1;
  }

  .testi-author {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .testi-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--pink-pale);
  }

  .testi-name {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--charcoal);
  }

  .testi-src {
    font-size: 0.7rem;
    color: var(--text-muted);
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .testi-src svg {
    width: 12px;
    height: 12px;
    color: #22C55E;
  }

  .testi-note {
    text-align: center;
    margin-top: 28px;
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .testi-note a {
    color: var(--pink);
    font-weight: 600;
  }

  @media (min-width: 768px) {
    .testi-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .testi-grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media (min-width: 1320px) {
    .testi-grid { grid-template-columns: repeat(4, 1fr); }
  }

  @media (max-width: 767px) {
    .testimonials {
      padding: 84px 0;
    }

    .testimonials-header {
      margin-bottom: 36px;
    }

    .testi-card {
      padding: 20px 18px;
    }

    .testi-note {
      font-size: 0.76rem;
      line-height: 1.7;
      text-align: left;
    }
  }
</style>
