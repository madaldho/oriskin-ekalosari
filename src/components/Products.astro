---
const waLink = 'https://wa.me/6281288045939?text=Halo%20Oriskin%2C%20saya%20sudah%20siap%20reservasi.%20Kapan%20bisa%3F';

const products = [
  {
    title: 'Brightening Series',
    desc: 'Rangkaian produk pencerah wajah untuk kulit kusam, flek, dan bekas jerawat. Formulasi dokter dengan bahan aktif premium.',
    tag: 'Best Seller',
    image: '/product-brightening.jpg',
  },
  {
    title: 'Acne Care Series',
    desc: 'Produk khusus kulit berjerawat dengan antibakteri dan anti-inflamasi. Kontrol minyak tanpa bikin kering.',
    tag: 'Recommended',
    image: '/product-acne.jpg',
  },
  {
    title: 'Anti-Aging Series',
    desc: 'Kolagen booster dan retinol series untuk mengencangkan kulit, menyamarkan garis halus, dan tampak awet muda.',
    tag: 'Premium',
    image: '/product-antiaging.jpg',
  },
  {
    title: 'Daily Sunscreen SPF50+',
    desc: 'Sunscreen ringan dengan tekstur nyaman, perlindungan UVA/UVB maksimal. Cocok untuk daily use di bawah makeup.',
    tag: 'Wajib Punya',
    image: '/product-sunscreen.jpg',
  },
];
---

<section class="products" id="produk">
  <div class="container">
    <div class="products-header reveal">
      <p class="section-label">Produk Kami</p>
      <h2 class="section-title">Skincare by Oriskin</h2>
      <p class="section-subtitle">Produk perawatan kulit yang diformulasikan langsung oleh dokter spesialis kulit.</p>
    </div>
    <div class="products-grid">
      {products.map((product, i) => (
        <div class={`product-card reveal ${i > 0 ? `reveal-delay-${i}` : ''}`}>
          <div class="product-img">
            <img src={product.image} alt={product.title} width="600" height="600" loading="lazy" />
          </div>
          <div class="product-body">
            <span class="product-tag">{product.tag}</span>
            <h3>{product.title}</h3>
            <p>{product.desc}</p>
            <a href={waLink} class="product-link" target="_blank" rel="noopener">
              Tanya Produk
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .products {
    padding: 96px 0;
    background: linear-gradient(180deg, var(--bg) 0%, var(--pink-pale) 50%, var(--bg) 100%);
  }

  .products-header {
    text-align: center;
    margin-bottom: 48px;
  }

  .products-header .section-subtitle {
    margin: 0 auto;
  }

  .products-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
    align-items: stretch;
  }

  .product-card {
    background: var(--white);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    transition: all var(--transition);
    position: relative;
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow: hidden;
  }

  .product-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: rgba(232,123,123,0.2);
  }

  .product-img {
    width: 100%;
    aspect-ratio: 1;
    overflow: hidden;
    background: var(--bg);
  }

  .product-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .product-card:hover .product-img img {
    transform: scale(1.05);
  }

  .product-body {
    padding: 20px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .product-tag {
    display: inline-block;
    padding: 4px 12px;
    border-radius: 50px;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--pink-dark);
    background: var(--pink-pale);
    margin-bottom: 10px;
    width: fit-content;
  }

  .product-card h3 {
    font-size: 1.1rem;
    color: var(--charcoal);
    margin-bottom: 8px;
  }

  .product-card p {
    font-size: 0.86rem;
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 16px;
    flex: 1;
  }

  .product-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.84rem;
    font-weight: 600;
    color: var(--pink);
    transition: gap 0.25s;
  }

  .product-link:hover { gap: 12px; }

  .product-link svg {
    width: 15px;
    height: 15px;
  }

  @media (min-width: 768px) {
    .products-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .products-grid { grid-template-columns: repeat(4, 1fr); }
  }

  @media (max-width: 767px) {
    .products {
      padding: 84px 0;
    }

    .products-header {
      margin-bottom: 36px;
    }

    .products-grid {
      gap: 16px;
    }

    .product-card {
      /* image handles top, body handles padding */
    }
  }
</style>
