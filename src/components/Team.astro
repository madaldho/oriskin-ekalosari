---

<section class="team" id="tim">
  <div class="container">
    <div class="team-header reveal">
      <p class="section-label">Tim Kami</p>
      <h2 class="section-title">Ditangani oleh Ahlinya</h2>
      <p class="section-subtitle">Tim profesional kami siap memberikan perawatan terbaik untuk kulit Anda.</p>
    </div>

    <!-- Carousel Container -->
    <div class="team-carousel-wrapper reveal reveal-delay-1" id="teamCarousel">
      <div class="team-track" id="teamTrack">
        {teamMembers.map((member, index) => (
          <div class="team-card" data-index={index}>
            <img 
              src={member.image} 
              alt={member.name} 
              class="team-img"
              loading="lazy"
              width="300"
              height="360"
            />

            <!-- Gradient Overlay untuk teks -->
            <div class="team-overlay"></div>

            <!-- Konten / Informasi Beautician -->
            <div class="team-info">
              <div class="team-stars">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
              </div>
              
              <h3 class="team-name">{member.name}</h3>
              
              <p class="team-role">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>
                {member.role}
              </p>
              
              <!-- Deskripsi muncul saat card di tengah -->
              <div class="team-desc-container">
                <p class="team-desc">{member.desc}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Pagination Indicators -->
    <div class="team-dots">
      {teamMembers.map((_, index) => (
        <button 
          class="team-dot" 
          data-index={index}
          aria-label={`Go to slide ${index + 1}`}
        ></button>
      ))}
    </div>
  </div>
</section>

<script>
  const track = document.getElementById('teamTrack');
  const wrapper = document.getElementById('teamCarousel');
  const cards = track?.querySelectorAll('.team-card');
  const dots = document.querySelectorAll('.team-dot');
  
  let activeIndex = 0;
  let autoplayInterval: number | undefined;
  let isPaused = false;

  function getOffset(index: number): number {
    if (!cards) return 0;
    let diff = index - activeIndex;
    const length = cards.length;
    
    if (diff > length / 2) diff -= length;
    if (diff < -length / 2) diff += length;
    
    return diff;
  }

  function updateCarousel() {
    if (!cards || cards.length === 0) return;

    cards.forEach((card, index) => {
      const offset = getOffset(index);
      const isCenter = offset === 0;
      
      const translateX = offset * 115; 
      const scale = isCenter ? 1 : 0.85;
      const opacity = Math.abs(offset) > 1 ? 0 : (isCenter ? 1 : 0.4);
      const zIndex = 10 - Math.abs(offset);

      const el = card as HTMLElement;
      el.style.transform = `translate(calc(-50% + ${translateX}%), -50%) scale(${scale})`;
      el.style.opacity = opacity.toString();
      el.style.zIndex = zIndex.toString();
      el.style.visibility = Math.abs(offset) > 2 ? 'hidden' : 'visible';

      if (isCenter) {
        el.classList.add('active');
      } else {
        el.classList.remove('active');
      }
    });

    dots.forEach((dot, i) => {
      if (i === activeIndex) {
        dot.classList.add('active');
      } else {
        dot.classList.remove('active');
      }
    });
  }

  function nextSlide() {
    if (!cards) return;
    activeIndex = (activeIndex + 1) % cards.length;
    updateCarousel();
  }

  function goToSlide(index: number) {
    activeIndex = index;
    updateCarousel();
  }

  function startAutoplay() {
    stopAutoplay();
    autoplayInterval = window.setInterval(() => {
      if (!isPaused) nextSlide();
    }, 3000);
  }

  function stopAutoplay() {
    if (autoplayInterval) clearInterval(autoplayInterval);
  }

  cards?.forEach((card) => {
    card.addEventListener('click', () => {
      const idx = parseInt((card as HTMLElement).dataset.index || '0');
      goToSlide(idx);
    });
  });

  dots.forEach((dot) => {
    dot.addEventListener('click', () => {
      const idx = parseInt((dot as HTMLElement).dataset.index || '0');
      goToSlide(idx);
    });
  });

  wrapper?.addEventListener('mouseenter', () => isPaused = true);
  wrapper?.addEventListener('mouseleave', () => isPaused = false);

  // Swipe support for mobile
  let startX = 0;
  wrapper?.addEventListener('touchstart', (e) => { 
    startX = e.touches[0].clientX; 
    isPaused = true; 
  });
  wrapper?.addEventListener('touchend', (e) => {
    const diff = startX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 40) { 
      if (diff > 0) {
        nextSlide();
      } else {
        activeIndex = (activeIndex - 1 + (cards?.length || 0)) % (cards?.length || 1);
        updateCarousel();
      }
    }
    isPaused = false;
  });

  updateCarousel();
  startAutoplay();
</script>

<style>
  .team {
    padding: 96px 0;
    background: var(--white);
    overflow: hidden;
  }

  .team-header {
    text-align: center;
    margin-bottom: 48px;
  }

  .team-header .section-subtitle {
    margin: 0 auto;
  }

  /* Carousel Wrapper - Mechanics Only */
  .team-carousel-wrapper {
    position: relative;
    width: 100%;
    height: 65vh;
    max-height: 600px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .team-track {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .team-card {
    position: absolute;
    top: 50%;
    left: 50%;
    width: clamp(240px, 30vw, 320px);
    aspect-ratio: 1 / 1.7;
    border-radius: var(--radius-xl);
    overflow: hidden;
    cursor: pointer;
    transition: all 0.7s cubic-bezier(0.25, 1, 0.5, 1);
    transform: translate(-50%, -50%);
    border: 1px solid var(--border);
    box-shadow: var(--shadow-lg);
    background: var(--white);
  }

  .team-card.active {
    border: 4px solid var(--pink);
    box-shadow: 0 0 30px rgba(232, 123, 123, 0.4);
  }

  .team-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Gradient gelap di atas foto supaya teks putih terbaca */
  .team-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(45, 42, 50, 0.95) 0%,
      rgba(45, 42, 50, 0.4) 50%,
      transparent 100%
    );
    pointer-events: none;
  }

  .team-info {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    padding: 24px;
    transition: transform 0.5s ease;
    transform: translateY(1rem);
  }

  .team-card.active .team-info {
    transform: translateY(0);
  }

  .team-stars {
    display: flex;
    gap: 4px;
    margin-bottom: 8px;
  }

  .team-stars svg {
    width: 16px;
    height: 16px;
    color: var(--pink);
  }

  .team-name {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 4px;
    line-height: 1.2;
  }

  .team-role {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--pink-light);
    font-weight: 600;
    font-size: 0.95rem;
    margin-bottom: 12px;
  }

  .team-role svg {
    width: 16px;
    height: 16px;
  }

  .team-desc-container {
    max-height: 0;
    opacity: 0;
    overflow: hidden;
    transition: all 0.5s ease;
  }

  .team-card.active .team-desc-container {
    max-height: 120px;
    opacity: 1;
    margin-top: 8px;
  }

  .team-desc {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.6;
    border-top: 1px solid rgba(255, 255, 255, 0.2);
    padding-top: 12px;
  }

  /* Dots */
  .team-dots {
    display: flex;
    gap: 10px;
    justify-content: center;
    margin-top: 32px;
    position: relative;
    z-index: 20;
  }

  .team-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--border);
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
    padding: 0;
  }

  .team-dot:hover {
    background: var(--pink-pale);
  }

  .team-dot.active {
    width: 28px;
    background: var(--pink);
    box-shadow: 0 0 10px rgba(232, 123, 123, 0.5);
    border-radius: 4px;
  }

  @media (max-width: 768px) {
    .team {
      padding: 84px 0;
    }

    .team-carousel-wrapper {
      height: 55vh;
      min-height: 480px;
    }

    .team-card {
      width: clamp(240px, 70vw, 300px);
    }
  }
</style>
