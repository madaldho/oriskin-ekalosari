---
const teamMembers = [
  {
    id: 1,
    name: "Sari Dewi, S.Kep",
    role: "Head Beautician",
    desc: "Certified beautician dengan pelatihan internasional.",
    image: "/doctor-portrait.png"
  },
  {
    id: 2,
    name: "Rina Melati, Amd.Keb",
    role: "Senior Aesthetician",
    desc: "Spesialis perawatan anti-aging dan acne treatment klinik.",
    image: "/doctor-portrait.png"
  },
  {
    id: 3,
    name: "Siska Amanda, S.Gz",
    role: "Beauty & Nutrition",
    desc: "Ahli nutrisi kulit, tersertifikasi perawatan body contouring.",
    image: "/doctor-portrait.png"
  },
  {
    id: 4,
