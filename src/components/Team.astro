---

<section class="team" id="tim">
  <!-- Background Decor (Blur/Glow Pink) -->
  <div class="team-glow-bg"></div>

  <div class="container">
    <div class="team-header reveal">
      <div class="header-icon-wrapper">
        <svg xmlns="http://www.w3.org/2000/svg" class="header-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/>
        </svg>
        <h2 class="section-title">
          Tim <span class="text-gradient">Beautician Ahli</span>
        </h2>
      </div>
      <p class="section-subtitle">Profesional tersertifikasi untuk perawatan kulit Anda</p>
    </div>

    <!-- Carousel Container -->
    <div class="team-carousel-wrapper" id="teamCarousel">
      <div class="team-track" id="teamTrack">
        {teamMembers.map((member, index) => (
          <div class="team-card" data-index={index}>
            <img 
              src={member.image} 
              alt={member.name} 
              class="team-img"
              loading="lazy"
            />

            <!-- Gradient Overlay untuk teks -->
            <div class="team-overlay"></div>

            <!-- Konten / Informasi Beautician -->
            <div class="team-info">
              <div class="team-stars">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
              </div>
              
              <h3 class="team-name">{member.name}</h3>
              
              <p class="team-role">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>
                {member.role}
              </p>
              
              <!-- Deskripsi muncul saat card di tengah -->
              <div class="team-desc-container">
                <p class="team-desc">{member.desc}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Pagination Indicators -->
    <div class="team-dots">
      {teamMembers.map((_, index) => (
        <button 
          class="team-dot" 
          data-index={index}
          aria-label={`Go to slide ${index + 1}`}
        ></button>
      ))}
    </div>
  </div>
</section>

<script>
  const track = document.getElementById('teamTrack');
  const wrapper = document.getElementById('teamCarousel');
  const cards = track?.querySelectorAll('.team-card');
  const dots = document.querySelectorAll('.team-dot');
  
  let activeIndex = 0;
  let autoplayInterval: number | undefined;
  let isPaused = false;

  function getOffset(index: number): number {
    if (!cards) return 0;
    let diff = index - activeIndex;
    const length = cards.length;
    
    if (diff > length / 2) diff -= length;
    if (diff < -length / 2) diff += length;
    
    return diff;
  }

  function updateCarousel() {
    if (!cards || cards.length === 0) return;

    cards.forEach((card, index) => {
      const offset = getOffset(index);
      const isCenter = offset === 0;
      
      const translateX = offset * 115; 
      const scale = isCenter ? 1 : 0.85;
      const opacity = Math.abs(offset) > 1 ? 0 : (isCenter ? 1 : 0.4);
      const zIndex = 10 - Math.abs(offset);

      const el = card as HTMLElement;
      el.style.transform = `translate(calc(-50% + ${translateX}%), -50%) scale(${scale})`;
      el.style.opacity = opacity.toString();
      el.style.zIndex = zIndex.toString();
      el.style.visibility = Math.abs(offset) > 2 ? 'hidden' : 'visible';

      if (isCenter) {
        el.classList.add('active');
      } else {
        el.classList.remove('active');
      }
    });

    dots.forEach((dot, i) => {
      if (i === activeIndex) {
        dot.classList.add('active');
      } else {
        dot.classList.remove('active');
      }
    });
  }

  function nextSlide() {
    if (!cards) return;
    activeIndex = (activeIndex + 1) % cards.length;
    updateCarousel();
  }

  function goToSlide(index: number) {
    activeIndex = index;
    updateCarousel();
  }

  function startAutoplay() {
    stopAutoplay();
    autoplayInterval = window.setInterval(() => {
      if (!isPaused) nextSlide();
    }, 3000);
  }

  function stopAutoplay() {
    if (autoplayInterval) clearInterval(autoplayInterval);
  }

  cards?.forEach((card) => {
    card.addEventListener('click', () => {
      const idx = parseInt((card as HTMLElement).dataset.index || '0');
      goToSlide(idx);
    });
  });

  dots.forEach((dot) => {
    dot.addEventListener('click', () => {
      const idx = parseInt((dot as HTMLElement).dataset.index || '0');
      goToSlide(idx);
    });
  });

  wrapper?.addEventListener('mouseenter', () => isPaused = true);
  wrapper?.addEventListener('mouseleave', () => isPaused = false);

  updateCarousel();
  startAutoplay();
</script>

<style>
  .team {
    position: relative;
    padding: 96px 0;
    background: #020617; /* slate-950 equivalent */
    color: white;
    overflow: hidden;
  }

  .team-glow-bg {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 80vw;
    height: 80vh;
    background: rgba(236, 72, 153, 0.1);
    filter: blur(120px);
    border-radius: 50%;
    pointer-events: none;
    z-index: 0;
  }

  .container {
    position: relative;
    z-index: 10;
  }

  .team-header {
    text-align: center;
    margin-bottom: 24px;
    position: relative;
    z-index: 20;
  }

  .header-icon-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    margin-bottom: 8px;
  }

  .header-icon {
    width: 32px;
    height: 32px;
    color: var(--pink);
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  .section-title {
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    color: white;
    margin: 0;
  }

  .text-gradient {
    background: linear-gradient(to right, #f472b6, #db2777); /* pink-400 to pink-600 */
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .section-subtitle {
    color: #94a3b8; /* slate-400 */
    font-size: clamp(0.9rem, 2vw, 1rem);
    margin-top: 8px;
  }

  /* Carousel */
  .team-carousel-wrapper {
    position: relative;
    width: 100%;
    height: 70vh;
    max-height: 700px;
    margin-top: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .team-track {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .team-card {
    position: absolute;
    top: 50%;
    left: 50%;
    width: clamp(240px, 30vw, 320px);
    aspect-ratio: 1 / 1.9;
    border-radius: 2rem;
    overflow: hidden;
    cursor: pointer;
    transition: all 0.7s cubic-bezier(0.25, 1, 0.5, 1);
    transform: translate(-50%, -50%);
    border: 1px solid #334155; /* slate-700 */
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.5);
  }

  .team-card.active {
    border: 4px solid #ec4899; /* pink-500 */
    box-shadow: 0 0 30px rgba(236, 72, 153, 0.5);
  }

  .team-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .team-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      #020617 0%,
      rgba(15, 23, 42, 0.6) 40%,
      transparent 100%
    );
    pointer-events: none;
  }

  .team-info {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    padding: 24px;
    transition: transform 0.5s ease;
    transform: translateY(1rem);
  }

  .team-card.active .team-info {
    transform: translateY(0);
  }

  .team-stars {
    display: flex;
    gap: 4px;
    margin-bottom: 8px;
  }

  .team-stars svg {
    width: 16px;
    height: 16px;
    color: #f472b6; /* pink-400 */
  }

  .team-name {
    font-size: 1.5rem;
    font-weight: 700;
    color: white;
    margin-bottom: 4px;
    line-height: 1.2;
  }

  .team-role {
    display: flex;
    align-items: center;
    gap: 8px;
    color: #f472b6; /* pink-400 */
    font-weight: 500;
    font-size: 0.95rem;
    margin-bottom: 12px;
  }

  .team-role svg {
    width: 16px;
    height: 16px;
  }

  .team-desc-container {
    max-height: 0;
    opacity: 0;
    overflow: hidden;
    transition: all 0.5s ease;
  }

  .team-card.active .team-desc-container {
    max-height: 100px;
    opacity: 1;
    margin-top: 8px;
  }

  .team-desc {
    font-size: 0.875rem;
    color: #cbd5e1; /* slate-300 */
    line-height: 1.6;
    border-top: 1px solid rgba(255, 255, 255, 0.2);
    padding-top: 12px;
  }

  .team-dots {
    display: flex;
    gap: 12px;
    justify-content: center;
    margin-top: 40px;
    position: relative;
    z-index: 20;
  }

  .team-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #475569; /* slate-600 */
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
    padding: 0;
  }

  .team-dot:hover {
    background: #94a3b8; /* slate-400 */
  }

  .team-dot.active {
    width: 32px;
    background: #ec4899; /* pink-500 */
    box-shadow: 0 0 10px rgba(236, 72, 153, 0.8);
    border-radius: 8px;
  }

  @media (max-width: 768px) {
    .team {
      padding: 72px 0;
    }

    .team-carousel-wrapper {
      height: 60vh;
      margin-top: 48px;
    }

    .team-card {
      width: clamp(220px, 60vw, 280px);
    }
  }
</style>
