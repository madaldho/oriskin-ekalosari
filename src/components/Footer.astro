---
const waLink = 'https://wa.me/6281288045939?text=Halo%20Oriskin%2C%20saya%20mau%20konsultasi';

const serviceLinks = [
  { href: '#layanan', label: 'Facial Treatment' },
  { href: '#layanan', label: 'Laser Treatment' },
  { href: '#layanan', label: 'Chemical Peeling' },
  { href: '#produk', label: 'Skincare Products' },
];

const navLinks = [
  { href: '#layanan', label: 'Layanan' },
  { href: '#produk', label: 'Produk' },
  { href: '#tim', label: 'Tim Kami' },
  { href: '#testimoni', label: 'Testimoni' },
  { href: '#faq', label: 'FAQ' },
  { href: '#lokasi', label: 'Lokasi' },
];
---

<footer class="footer" role="contentinfo">
  <div class="container">
    <div class="footer-top">
      <div class="footer-brand-col">
        <div class="footer-brand-row">
          <img src="/logo-oriskin.png" alt="Oriskin" class="footer-logo" />
          <div class="footer-brand-text">Ori<em>skin</em> <small>Ekalokasari</small></div>
        </div>
        <p class="footer-desc">Klinik kecantikan premium di Bogor dengan perawatan profesional dan teknologi terkini untuk kulit sehat dan bercahaya.</p>
        <div class="footer-socials">
          <a href="https://instagram.com/oriskinekalokasari" target="_blank" rel="noopener" aria-label="Instagram" class="footer-social">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
          </a>
          <a href={waLink} target="_blank" rel="noopener" aria-label="WhatsApp" class="footer-social">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51l-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.981.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
          </a>
        </div>
      </div>
      <div class="footer-col">
        <h4 class="footer-heading">Layanan</h4>
        <ul class="footer-links">
          {serviceLinks.map(link => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>
      <div class="footer-col">
        <h4 class="footer-heading">Navigasi</h4>
        <ul class="footer-links">
          {navLinks.map(link => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>
      <div class="footer-col">
        <h4 class="footer-heading">Kontak</h4>
        <ul class="footer-links footer-contact">
          <li>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            <a href="tel:+6281288045939">0812-8804-5939</a>
          </li>
          <li>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            <span>Lippo Plaza Bogor 1, Lt.UG #3<br>Jl. Siliwangi No.123 Ekalokasari</span>
          </li>
          <li>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            <span>Senin – Sabtu: 09.00 – 22.00</span>
          </li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <p>© 2026 Oriskin Ekalokasari Bogor. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: #2D2A32;
    color: rgba(255,255,255,0.5);
    padding: 56px 0 24px;
  }

  .footer-top {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1.3fr;
    gap: 40px;
    margin-bottom: 40px;
  }

  .footer-brand-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 14px;
  }

  .footer-logo {
    width: 32px;
    height: 32px;
    object-fit: contain;
  }

  .footer-brand-text {
    font-family: 'Lora', serif;
    font-size: 1.15rem;
    font-weight: 600;
    color: rgba(255,255,255,0.85);
  }

  .footer-brand-text em {
    font-style: normal;
    color: var(--pink-light);
  }

  .footer-brand-text small {
    display: block;
    font-size: 0.65rem;
    font-weight: 400;
    color: rgba(255,255,255,0.35);
    font-family: 'Plus Jakarta Sans', sans-serif;
    letter-spacing: 1px;
    text-transform: uppercase;
    margin-top: -2px;
  }

  .footer-desc {
    font-size: 0.82rem;
    line-height: 1.7;
    color: rgba(255,255,255,0.4);
    margin-bottom: 18px;
  }

  .footer-socials {
    display: flex;
    gap: 8px;
  }

  .footer-social {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.08);
    display: grid;
    place-items: center;
    transition: all 0.25s;
  }

  .footer-social:hover {
    background: var(--pink);
    border-color: var(--pink);
  }

  .footer-social svg {
    width: 16px;
    height: 16px;
    color: rgba(255,255,255,0.5);
  }

  .footer-social:hover svg {
    color: white;
  }

  .footer-heading {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.82rem;
    font-weight: 700;
    color: rgba(255,255,255,0.75);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 16px;
  }

  .footer-links {
    list-style: none;
  }

  .footer-links li {
    margin-bottom: 8px;
  }

  .footer-links a, .footer-links span {
    font-size: 0.82rem;
    color: rgba(255,255,255,0.4);
    transition: color 0.25s;
    line-height: 1.6;
  }

  .footer-links a:hover {
    color: var(--pink-light);
  }

  .footer-contact li {
    display: flex;
    align-items: flex-start;
    gap: 8px;
  }

  .footer-contact svg {
    width: 15px;
    height: 15px;
    color: var(--pink-light);
    flex-shrink: 0;
    margin-top: 3px;
  }

  .footer-bottom {
    padding-top: 20px;
    border-top: 1px solid rgba(255,255,255,0.06);
    text-align: center;
  }

  .footer-bottom p {
    font-size: 0.72rem;
    color: rgba(255,255,255,0.2);
  }

  @media (max-width: 920px) {
    .footer-top {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 500px) {
    .footer-top {
      grid-template-columns: 1fr;
      gap: 28px;
    }
  }
</style>
