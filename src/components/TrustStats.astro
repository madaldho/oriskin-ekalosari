---
const stats = [
  { number: '5,000+', label: 'Pelanggan Puas' },
  { number: '15+', label: 'Tahun Pengalaman' },
  { number: '4.9', label: 'Rating Google' },
  { number: '50+', label: 'Cabang Nasional' },
];
---

<section class="trust" aria-label="Statistik kepercayaan">
  <div class="container">
    <div class="trust-grid">
      {stats.map((stat, i) => (
        <div class={`trust-item reveal ${i > 0 ? `reveal-delay-${i}` : ''}`}>
          <div class="trust-number">{stat.number}</div>
          <div class="trust-label">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .trust {
    padding: 48px 0;
    background: var(--blush);
  }

  .trust-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
    text-align: center;
  }

  .trust-item {
    padding: 18px 12px;
  }

  .trust-number {
    font-family: 'Lora', serif;
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    font-weight: 700;
    color: var(--pink-dark);
    line-height: 1;
    margin-bottom: 6px;
  }

  .trust-label {
    font-size: 0.85rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  @media (min-width: 768px) {
    .trust-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
</style>
