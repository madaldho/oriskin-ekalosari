---
const stats = [
  { number: '5.000+', label: 'Pasien Puas' },
  { number: '10+', label: 'Tahun Pengalaman' },
  { number: '4.9', label: 'Rating Google' },
];
---

<section class="trust" aria-label="Statistik kepercayaan">
  <div class="container">
    <div class="trust-grid">
      {stats.map((stat, i) => (
        <div class={`trust-item reveal ${i > 0 ? `reveal-delay-${i}` : ''}`}>
          <div class="trust-number">{stat.number}</div>
          <div class="trust-label">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .trust {
    padding: 64px 0;
    background: var(--white);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .trust-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    text-align: center;
  }

  .trust-item {
    padding: 24px 16px;
  }

  .trust-number {
    font-family: 'Lora', serif;
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 700;
    color: var(--terracotta);
    margin-bottom: 8px;
  }

  .trust-label {
    font-size: 0.9rem;
    color: var(--text-muted);
    font-weight: 500;
  }
</style>
