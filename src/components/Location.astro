---
const hours = [
  { day: 'Senin - Sabtu', time: '09:00 - 22:00 WIB', closed: false },
  { day: 'Minggu', time: 'Tutup', closed: true },
];
const mapsUrl = 'https://www.google.com/maps/place/Oriskin+Ekalokasari/@-6.6119598,106.8066319,17z';
---

<section class="location" id="lokasi">
  <div class="container">
    <div class="location-header reveal">
      <p class="section-label">Lokasi</p>
      <h2 class="section-title">Kunjungi Klinik Kami</h2>
      <p class="section-subtitle">Berlokasi strategis di Lippo Plaza Ekalokasari, Bogor. Mudah dijangkau dan tersedia parkir luas.</p>
    </div>
    <div class="location-grid">
      <div class="location-map reveal">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3963.2!2d106.8066319!3d-6.6119598!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2e69c5e67e662dfb%3A0x3cb3ffafe6b4b579!2sOriskin%20Ekalokasari!5e0!3m2!1sid!2sid!4v1700000000000"
          width="600"
          height="400"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Lokasi Oriskin Ekalokasari di Google Maps"
        ></iframe>
      </div>
      <div class="location-details reveal reveal-delay-1">
        <div class="location-item">
          <div class="location-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <div>
            <h4>Alamat</h4>
            <p>Lippo Plaza Bogor 1, Jl. Siliwangi No.123 Ekalokasari) Lt.UG #3, RT.01/RW.04, Sukasari, Kec. Bogor Tim., Kota Bogor, Jawa Barat 16142, Indonesia</p>
            <a href={mapsUrl} class="maps-link" target="_blank" rel="noopener">Lihat di Google Maps →</a>
          </div>
        </div>
        <div class="location-item">
          <div class="location-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </div>
          <div>
            <h4>Telepon / WhatsApp</h4>
            <p><a href="tel:+6281288045939">0812-8804-5939</a></p>
          </div>
        </div>
        <div class="location-item">
          <div class="location-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <div>
            <h4>Jam Operasional</h4>
            <div class="location-hours">
              {hours.map(h => (
                <div class={`hour-row ${h.closed ? 'closed' : ''}`}>
                  <span class="day">{h.day}</span>
                  <span class="time">{h.time}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .location {
    padding: 96px 0;
  }

  .location-header {
    text-align: center;
    margin-bottom: 56px;
  }

  .location-header .section-subtitle {
    margin: 0 auto;
  }

  .location-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
  }

  .location-map {
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
    border: 1px solid var(--border);
  }

  .location-map iframe {
    width: 100%;
    height: 280px;
    display: block;
  }

  .location-details {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .location-item {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }

  .location-icon {
    width: 44px;
    height: 44px;
    background: var(--pink-pale);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .location-icon svg {
    width: 20px;
    height: 20px;
    color: var(--pink-dark);
  }

  .location-item h4 {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.95rem;
    font-weight: 600;
    margin-bottom: 4px;
  }

  .location-item p {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .location-item a {
    color: var(--text-muted);
    transition: color var(--transition);
  }

  .location-item a:hover {
    color: var(--pink);
  }

  .maps-link {
    display: inline-block;
    margin-top: 8px;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--pink) !important;
  }

  .maps-link:hover {
    text-decoration: underline;
  }

  .location-hours {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
    margin-top: 8px;
  }

  .hour-row {
    display: flex;
    justify-content: space-between;
    padding: 10px 16px;
    background: var(--bg);
    border-radius: var(--radius-sm);
    font-size: 0.875rem;
  }

  .hour-row .day {
    font-weight: 600;
    color: var(--charcoal);
  }

  .hour-row .time {
    color: var(--text-muted);
  }

  .hour-row.closed .time {
    color: var(--pink);
    font-weight: 600;
  }

  @media (min-width: 768px) {
    .location-grid {
      grid-template-columns: 1fr 1fr;
    }

    .location-map iframe {
      height: 100%;
      min-height: 320px;
    }
  }
</style>
